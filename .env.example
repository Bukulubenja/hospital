SECRET_KEY=change-me-to-a-unique-random-value
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=HMS
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# Password-reset emails print to the console by default (no setup needed for
# dev). To actually deliver them, switch to the SMTP backend and fill in
# your provider's credentials:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-smtp-username
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
