# Generate a real value with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Never reuse the auto-generated 'django-insecure-...' dev key outside a laptop.
SECRET_KEY=change-me-to-a-unique-random-value
DEBUG=True

# Multi-tenant routing: each hospital is served at <subdomain>.BASE_DOMAIN,
# resolved per-request by hospital.middleware.TenantMiddleware. The bare
# BASE_DOMAIN (no subdomain) is the platform/no-tenant path, reachable only
# by a hospital=None superuser via Django's /admin/ to create new Hospital
# tenants — see CLAUDE.md's tenancy section.
#
# Local dev: lvh.me publicly resolves *.lvh.me to 127.0.0.1, so subdomains
# work with zero hosts-file editing — visit e.g. stjohns.lvh.me:8000.
# ALLOWED_HOSTS needs the matching leading-dot wildcard entry.
BASE_DOMAIN=lvh.me:8000
ALLOWED_HOSTS=.lvh.me,localhost,127.0.0.1
# Production example:
# BASE_DOMAIN=hms.example.com
# ALLOWED_HOSTS=.hms.example.com,hms.example.com

DB_NAME=HMS
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# Leave all of these False/0 for local HTTP dev. In production, once the
# site is served over HTTPS (directly or behind a TLS-terminating proxy),
# set:
#   SECURE_SSL_REDIRECT=True
#   SESSION_COOKIE_SECURE=True
#   CSRF_COOKIE_SECURE=True
#   SECURE_HSTS_SECONDS=31536000
#   SECURE_HSTS_INCLUDE_SUBDOMAINS=True
#   SECURE_HSTS_PRELOAD=True
# Read https://docs.djangoproject.com/en/6.0/topics/security/#ssl-https
# before enabling HSTS — a wrong config here can lock out HTTP for a year.
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Password-reset emails print to the console by default (no setup needed for
# dev). To actually deliver them, switch to the SMTP backend and fill in
# your provider's credentials:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.yourprovider.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-smtp-username
# EMAIL_HOST_PASSWORD=your-smtp-password
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
